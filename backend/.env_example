DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=alphaguard_ai_db
DB_SSLMODE=disable
# If register returns Not Found locally, port 8080 may be another app — use e.g. 8095 here and restart API + `npm run dev`.
SERVER_PORT=8080

# Set to 1 when connecting to an already-migrated DB and migrate would block (same DB as deployed app).
SKIP_DB_MIGRATE=0

# JWT for API auth (minimum 16 characters)
JWT_SECRET=replace-with-strong-random-string
# User session duration in hours (default 72, max 720)
JWT_EXPIRY_HOURS=72

# Admin panel (/admin): required on the server — no default password in the app
ADMIN_LOGIN=
ADMIN_PASSWORD=

# Dataset binary files live ONLY on the machine running the API (use absolute path if you start «go run» from another cwd).
# Remote PostgreSQL holds metadata/labels — not pixel data. For PC-only storage: run API locally + ./run-local.sh sets STORAGE_ROOT to project/backend/storage.
STORAGE_ROOT=./storage

# Base URL users open in browser (for verification email links).
# Production: http://YOUR_SERVER_IP  or https://your.domain
PUBLIC_APP_URL=http://127.0.0.1

# Optional SMTP (if empty, verification_url is returned on register for admins)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=
